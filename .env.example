# Firebase Configuration - PLANTILLA
# ⚠️ Copia este archivo como .env y completa con tus propias claves de Firebase

# Web
FIREBASE_WEB_API_KEY=tu_api_key_aqui
FIREBASE_WEB_APP_ID=tu_app_id_aqui
FIREBASE_WEB_MESSAGING_SENDER_ID=tu_messaging_sender_id_aqui
FIREBASE_WEB_PROJECT_ID=tu_project_id_aqui
FIREBASE_WEB_AUTH_DOMAIN=tu_auth_domain_aqui
FIREBASE_WEB_STORAGE_BUCKET=tu_storage_bucket_aqui
FIREBASE_WEB_MEASUREMENT_ID=tu_measurement_id_aqui

